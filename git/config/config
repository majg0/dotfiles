	gpgSign = true
[core]
	autocrlf = input
[gpg]
	format = ssh
[gpg "ssh"]
	program = "/opt/1Password/op-ssh-sign"
[init]
	defaultBranch = main
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[tag]
	gpgSign = true
